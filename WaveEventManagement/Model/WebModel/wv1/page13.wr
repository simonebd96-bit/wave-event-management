      <DisplayAttributes classServiceAttribute="WaveEventManagementData$att14"/>
      <DisplayAttributes classServiceAttribute="WaveEventManagementData$att18"/>
      <DisplayAttributes classServiceAttribute="WaveEventManagementData$att19"/>
      <DisplayAttributes classServiceAttribute="WaveEventManagementData$att9"/>
      <DisplayAttributes classServiceAttribute="WaveEventManagementData$att102"/>
    </List>
    <Form gr:x="0" gr:y="120" id="wv1#page13#frm4" name="Esegui Prenotazione">
      <Events>
        <OnSelectEvent id="wv1#page13#frm4#oslte4" name="prenota" validate="true">
          <NavigationFlow id="wv1#page13#frm4#oslte4#nf4" to="wv1#act9" name="aggiungi prenotazione">
            <ParameterBinding id="wv1#page13#frm4#oslte4#nf4#par19" source="{wv1#page13#frm4#fld8}value" target="wv1#act9.WaveEventManagementData$pdp35" name="Data Prenotazione - Data Prenotazione"/>
            <ParameterBinding id="wv1#page13#frm4#oslte4#nf4#par20" source="{wv1#page13#frm4#fld7}value" target="wv1#act9.WaveEventManagementData$pdp2" name="Codice Evento - EVENTO_2.Codice Evento(PrenotazioneToEvento)"/>
            <ParameterBinding id="wv1#page13#frm4#oslte4#nf4#par21" sourceParameter="wv1#page13#prd1" target="wv1#act9.WaveEventManagementData$pdp7" name="Codice_Utente - User.codice_user(PrenotazioneToUser)"/>
            <ParameterBinding id="wv1#page13#frm4#oslte4#nf4#par29" source="wv1#page13#prd2" passing="true" name="Username - PASSING"/>
            <ParameterBinding id="wv1#page13#frm4#oslte4#nf4#par32" source="wv1#page13#prd1" passing="true" name="Codice_Utente - PASSING"/>
