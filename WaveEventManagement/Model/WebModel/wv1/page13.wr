<Page xmlns:gr="http://www.webratio.com/2006/WebML/Graph" gr:x="560" gr:y="660" id="wv1#page13" name="Ricerca Eventi Pubblici">
  <ViewComponents>
    <List id="wv1#page13#lst9" checkable="false" distinct="false" gr:x="10" gr:y="0" name="Eventi Pubblici">
      <DataBinding classServiceRes="WaveEventManagementData$cls2"/>
      <SortAttribute classServiceAttribute="WaveEventManagementData$att13" direction="asc"/>
      <ConditionalExpression id="wv1#page13#lst9#sc4" defaultPolicy="fill" booleanOperator="and">
        <AttributesCondition id="wv1#page13#lst9#sc4#acond4" name="eventi not utente in sessione" predicate="neq" booleanOperator="and" implied="false">
          <AttributesConditionAttr classServiceAttribute="WaveEventManagementData$att102"/>
        </AttributesCondition>
      </ConditionalExpression>
      <DisplayAttributes classServiceAttribute="WaveEventManagementData$att11"/>
