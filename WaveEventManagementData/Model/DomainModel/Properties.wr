<DomainModel xmlns:db="http://www.webratio.com/2006/WebML/Database" xmlns:gr="http://www.webratio.com/2006/WebML/Graph" xmlns:srs="http://www.webratio.com/2017/IFML/ServerResources">
  <!-- ============================================================ -->
  <!-- USER                                                         -->
  <!-- ============================================================ -->
  <Class id="User" name="User" duration="persistent" gr:x="75" gr:y="145" gr:hideAttributes="false" attributeOrder="userOID userName secretKey User#att1 User#att2 User#att3 User#att20 User#att30 User#att31" volatileStorage="database" db:database="dbD1" db:table="USER_3">
    <Attribute name="codice_user" id="userOID" type="integer" key="true" db:column="CODICE_USER" db:autoIncrement="true"/>
    <Attribute name="username" id="userName" type="string" key="false" db:column="USERNAME"/>
    <Attribute id="secretKey" name="Secret Key" type="password" key="false" db:column="SECRET_KEY"/>
    <Attribute id="User#att1" name="nome" type="string" key="false" db:column="NOME"/>
    <Attribute id="User#att2" name="cognome" type="string" key="false" db:column="COGNOME"/>
    <Attribute id="User#att3" name="email" type="string" key="false" db:column="EMAIL"/>
    <Attribute id="User#att20" name="eta" type="integer" key="false" db:column="ETA"/>
    <Attribute id="User#att30" name="saldo_wallet" type="decimal" key="false" db:column="SALDO_WALLET"/>
    <Attribute id="User#att31" name="password" type="string" key="false" db:column="PASSWORD"/>
    <Comment xml:space="preserve">Rappresenta un utente registrato dell'applicazione Weave. Pu&#242; essere organizzatore (con abbonamento attivo) o partecipante.</Comment>
  </Class>
