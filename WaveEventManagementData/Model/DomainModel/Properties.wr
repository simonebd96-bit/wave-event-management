    <AssociationRole2 id="as6#role12" name="BachecaToMessaggio" maxCard="N">
      <db:JoinColumn attribute="cls4#att23" name="bacheca_codice_bacheca"/>
    </AssociationRole2>
  </Association>
  <Association id="as7" name="Messaggio_User" sourceClass="cls5" targetClass="User" db:database="dbD1" db:table="messaggio">
