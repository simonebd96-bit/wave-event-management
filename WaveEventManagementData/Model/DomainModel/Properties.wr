  <Association id="as1" name="User_Prenotazione" sourceClass="User" targetClass="cls1" db:database="dbD1" db:table="prenotazione">
    <AssociationRole1 id="as1#role1" name="UserToPrenotazione" maxCard="N">
      <db:JoinColumn attribute="userOID" name="user_3_codice_user"/>
    </AssociationRole1>
    <AssociationRole2 id="as1#role2" name="PrenotazioneToUser" maxCard="1" db:column="USER_CODICE_UTENTE">
      <db:JoinColumn attribute="cls1#att5" name="codice_prenotazione"/>
    </AssociationRole2>
  </Association>
  <Association id="as2" name="Prenotazione_Evento" sourceClass="cls1" targetClass="cls2" db:database="dbD1" db:table="prenotazione">
    <AssociationRole1 id="as2#role3" name="PrenotazioneToEvento" maxCard="1" db:column="EVENTO_CODICE_EVENTO">
      <db:JoinColumn attribute="cls1#att5" name="codice_prenotazione"/>
    </AssociationRole1>
    <AssociationRole2 id="as2#role4" name="EventoToPrenotazione" maxCard="N">
      <db:JoinColumn attribute="cls2#att9" name="evento_codice_evento"/>
    </AssociationRole2>
  </Association>
